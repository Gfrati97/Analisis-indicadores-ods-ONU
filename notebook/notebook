        "        .mean()\n",
        "        .dropna()\n",
        "    )\n",
        "\n",
        "    # Top 5 y bottom 5\n",
        "    top5 = datos_ind.nlargest(5)\n",
        "    bot5 = datos_ind.nsmallest(5)\n",
        "    comparar = pd.concat([top5, bot5]).sort_values()\n",
        "\n",
        "    # Color: verde si Argentina, azul si top, rojo si bottom\n",
        "    colores = []\n",
        "    for pais in comparar.index:\n",
        "        if pais == \"Argentina\":\n",
        "            colores.append(\"gold\")\n",
        "        elif pais in top5.index:\n",
        "            colores.append(\"steelblue\")\n",
        "        else:\n",
        "            colores.append(\"salmon\")\n",
        "\n",
        "    # Agregar Argentina si no está en top/bottom\n",
        "    arg_val = datos_ind.get(\"Argentina\", None)\n",
        "    if arg_val and \"Argentina\" not in comparar.index:\n",
        "        comparar[\"Argentina\"] = arg_val\n",
        "        comparar = comparar.sort_values()\n",
        "        colores = []\n",
        "        for pais in comparar.index:\n",
        "            if pais == \"Argentina\":\n",
