        "## Carga y limpieza de datos\n",
        "\n",
        "Cargamos los datos desde MongoDB seleccionando solo las columnas relevantes.\n",
        "Aplicamos las siguientes transformaciones:\n",
        "- Convertimos `value` a numérico\n",
        "- Filtramos solo países reales (excluimos regiones agregadas como \"World\", \"Africa\", etc.)\n",
        "- Filtramos el período 2000-2023 (2024-2025 tiene datos incompletos)"
      ],
      "metadata": {
        "id": "P8KGNLmgRegz"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Cargamos todo desde MongoDB\n",
        "# Nota: los campos con punto en el nombre (dimensions.Sex, etc.)\n",
        "# no se pueden filtrar con proyección, por eso traemos todo\n",
        "datos = list(col.find({}, {\"_id\": 0}))\n",
        "\n",
        "df = pd.DataFrame(datos)\n",
        "\n",
        "# Limpieza básica\n",
        "df[\"indicator\"] = df[\"indicator\"].apply(lambda x: x[0] if isinstance(x, list) else x)\n",
        "df[\"value\"] = pd.to_numeric(df[\"value\"], errors=\"coerce\")\n",
        "df[\"año\"] = df[\"timePeriodStart\"].astype(int)\n",
        "df = df.rename(columns={\n",
        "    \"geoAreaName\": \"pais\",\n",
        "    \"geoAreaCode\": \"codigo_pais\",\n",
        "    \"dimensions.Sex\": \"sexo\",\n",
        "    \"dimensions.Location\": \"ubicacion\",\n",
        "    \"dimensions.Education level\": \"nivel_educativo\"\n",
        "})\n",
        "\n",
        "df[\"codigo_pais\"] = pd.to_numeric(df[\"codigo_pais\"], errors=\"coerce\")\n",
        "\n",
        "# Códigos ONU de regiones y agregados (no son países individuales)\n",
        "CODIGOS_REGIONES = [\n",
        "    1, 2, 5, 9, 11, 13, 14, 15, 17, 18, 19, 21, 29, 30, 34, 35,\n",
        "    38, 39, 53, 54, 57, 61, 62, 142, 143, 145, 150, 151, 154,\n",
        "    155, 202, 419, 432, 513, 514, 515, 516, 518, 519, 520, 521,\n",
        "    522, 523, 524, 525, 526, 527, 528, 529, 530, 531, 532, 533,\n",
        "    680, 722, 723, 724, 725, 726, 727, 728, 729, 730, 731, 732,\n",
        "    733, 734, 735, 736, 737, 738, 739, 740, 741, 742, 743, 744,\n",
        "    745, 746, 747, 748, 749, 750, 751, 752, 753, 754, 755, 756,\n",
        "    757, 758, 759, 760, 761, 762, 763, 764, 765, 766, 767, 768,\n",
        "    769, 770, 771, 772, 773, 774, 775, 776, 777, 778, 779, 780,\n",
        "    900, 901, 902, 903, 904, 905, 906, 907, 908, 909, 910, 911,\n",
        "    912, 913, 914, 915, 916, 917, 918, 919, 920, 921, 922, 923,\n",
        "    924, 925, 926, 927, 928, 929, 930, 931, 932, 933, 934, 935\n",
        "]\n",
        "\n",
        "# Filtramos solo países reales y período 2000-2023\n",
        "df_paises = df[\n",
        "    (~df[\"codigo_pais\"].isin(CODIGOS_REGIONES)) &\n",
        "    (df[\"año\"] <= 2023)\n",
        "].copy()\n",
        "\n",
        "print(f\"Registros totales:       {len(df):,}\")\n",
        "print(f\"Solo países (2000-2023): {len(df_paises):,}\")\n",
        "print(f\"Países únicos:           {df_paises['pais'].nunique()}\")\n",
        "print(f\"Rango de años:           {df_paises['año'].min()} - {df_paises['año'].max()}\")"
      ],
