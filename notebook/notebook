      "source": [
        "# Top 10 y Bottom 10 países por indicador (promedio 2015-2023)\n",
        "# Usamos 2015-2023 para tener datos más recientes y representativos\n",
        "\n",
        "fig, axes = plt.subplots(3, 2, figsize=(16, 18))\n",
        "axes = axes.flatten()\n",
        "\n",
        "indicadores_orden = [\"4.1.2\", \"4.3.1\", \"4.6.1\", \"8.1.1\", \"8.5.2\", \"8.6.1\"]\n",
        "\n",
        "for i, ind in enumerate(indicadores_orden):\n",
        "    datos_ind = (\n",
        "        df_base[(df_base[\"indicator\"] == ind) & (df_base[\"año\"] >= 2015)]\n",
